# ============================================================
# 水利工地质量安全监管系统 - 环境变量配置
# 复制此文件为 .env 后填入实际值
# ============================================================

# ── ThingsBoard ────────────────────────────────────────────
# ThingsBoard 数据库密码
TB_DB_PASSWORD=thingsboard

# 传感器采集器使用的设备访问令牌
# 在 ThingsBoard 界面：设备 → 复制访问令牌
TB_SENSOR_TOKEN=YOUR_THINGSBOARD_SENSOR_TOKEN

# ── 飞书机器人 ────────────────────────────────────────────
# 飞书机器人 Webhook URL
# 在飞书群设置 → 群机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=

# ── JWT 安全 ──────────────────────────────────────────────
# 生产环境请修改为随机字符串（建议 32+ 字符）
JWT_SECRET=change-me-to-a-random-secret-in-production

# ── EasyDarwin 流媒体 ─────────────────────────────────────
EASY_DARWIN_URL=http://easy-darwin:8080

# ── 可选：外部数据库 ──────────────────────────────────────
# 如使用外部 PostgreSQL，取消下面的注释
# DATABASE_URL=postgresql://user:password@host:5432/water_safety
